# Backend Deployment Environment Target Variables
# Modify and rename this file to `.env` on production servers

# Express Running Port
PORT=5000

# Cloud MongoDB Database URL
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ai-voice?retryWrites=true&w=majority

# Secure UUID/String for JWT token generation
JWT_SECRET=production_secret_do_not_share_123!

# OpenRouter SDK / OpenAI Routing Key
OPENROUTER_API_KEY=sk-or-v1-...

# Restrict the app specifically to your frontend's deployed cloud address
CLIENT_URL=https://your-frontend-domain.vercel.app
