{
  "name": "interviewhack",
  "version": "1.0.0",
  "description": "Desktop Interview Assistant Foundation",
  "main": "electron/main.js",
  "scripts": {
    "server:dev": "npm start --prefix server",
    "client:dev": "npm run dev --prefix client -- --port 5173 --strictPort",
    "electron:dev": "concurrently \"npm run server:dev\" \"npm run client:dev\" \"wait-on tcp:5000 && wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "start": "npm run electron:dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "wait-on": "^7.2.0"
  },
  "bugs": {
    "url": "https://github.com/evil-sandeep/interviewhack/issues"
  },
  "homepage": "https://github.com/evil-sandeep/interviewhack#readme"
}
